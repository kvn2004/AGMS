{
  "info": {
    "_postman_id": "agms-collection-2026",
    "name": "AGMS - Automated Greenhouse Management System",
    "description": "Complete API collection for AGMS microservices\n\nBase URL: http://localhost:8080\n\nPrerequisites:\n1. Get JWT token from IoT Backend API\n2. Add token to Authorization header in Postman environment\n3. Start all services before testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. IoT Backend Authentication",
      "description": "Get JWT token from external IoT provider",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"shamodha\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://104.211.95.241:8080/api/auth/register",
              "protocol": "http",
              "host": ["104", "211", "95", "241"],
              "port": "8080",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login & Get Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('jwt_token', jsonData.accessToken);",
                  "    pm.environment.set('refresh_token', jsonData.refreshToken);",
                  "    console.log('✅ JWT Token saved to environment');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"shamodha\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://104.211.95.241:8080/api/auth/login",
              "protocol": "http",
              "host": ["104", "211", "95", "241"],
              "port": "8080",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "http://104.211.95.241:8080/api/auth/refresh",
              "protocol": "http",
              "host": ["104", "211", "95", "241"],
              "port": "8080",
              "path": ["api", "auth", "refresh"]
            }
          }
        }
      ]
    },
    {
      "name": "1. Zone Management Service",
      "description": "Manage greenhouse zones and environmental thresholds",
      "item": [
        {
          "name": "Create Zone",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('zone_id', jsonData.id);",
                  "    pm.environment.set('device_id', jsonData.deviceId);",
                  "    console.log('✅ Zone created with ID:', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tomato Zone\",\n  \"minTemp\": 20,\n  \"maxTemp\": 30\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/zones",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "zones"]
            }
          }
        },
        {
          "name": "Get Zone by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/zones/{{zone_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "zones", "{{zone_id}}"]
            }
          }
        },
        {
          "name": "Update Zone Thresholds",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"minTemp\": 18,\n  \"maxTemp\": 32\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/zones/{{zone_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "zones", "{{zone_id}}"]
            }
          }
        },
        {
          "name": "Delete Zone",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/zones/{{zone_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "zones", "{{zone_id}}"]
            }
          }
        },
        {
          "name": "Zone Service Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8081/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["health"]
            }
          }
        }
      ]
    },
